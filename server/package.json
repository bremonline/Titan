{
  "name": "titan-game-server",
  "version": "1.0.0",
  "description": "Avalon Hill Titan multiplayer game server",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && node --watch dist/server.js",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "game",
    "titan",
    "avalon-hill",
    "multiplayer"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.3",
    "uuid": "^10.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  }
}
